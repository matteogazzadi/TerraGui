@page
@model TerraGui.Web.Pages.IndexModel
@{
    ViewData["Title"] = "Home";
}

<div class="tg-hero py-5">
    <div class="container">
        <div class="row justify-content-center text-center">
            <div class="col-lg-8">
                <h1 class="tg-hero-title mb-3">
                    Terraform <span class="tg-accent">tfvars</span> Generator
                </h1>
                <p class="tg-hero-sub mb-4">
                    Drop your <code>variables.tf</code> file and instantly get a form to fill in your Terraform variables.
                    Download a ready-to-use <code>terraform.tfvars</code> file in seconds.
                </p>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    <!-- Drop Zone -->
    <div class="row justify-content-center mb-4">
        <div class="col-lg-10">
            <div id="dropZone" class="tg-drop-zone" role="button" tabindex="0"
                 aria-label="Drop Terraform files here or click to select">
                <div class="tg-drop-content">
                    <div class="tg-drop-icon mb-3">
                        <i class="bi bi-cloud-upload"></i>
                    </div>
                    <h5 class="mb-2">Drop your Terraform files here</h5>
                    <p class="text-muted mb-3">
                        <code>variables.tf</code> required &nbsp;&bull;&nbsp;
                        <code>terraform.tfvars.example</code> optional &nbsp;&bull;&nbsp;
                        <code>main.tf</code> optional
                    </p>
                    <button type="button" class="btn btn-primary" id="selectFilesBtn">
                        <i class="bi bi-folder2-open me-2"></i>Select Files
                    </button>
                    <input type="file" id="fileInput" multiple accept=".tf,.tfvars,.tfvars.example"
                           class="d-none" aria-label="Select Terraform files" />
                </div>
            </div>

            <!-- File list -->
            <div id="fileList" class="tg-file-list mt-3 d-none">
                <div class="d-flex align-items-center justify-content-between mb-2">
                    <h6 class="mb-0 text-muted"><i class="bi bi-files me-2"></i>Selected files</h6>
                    <button type="button" class="btn btn-sm btn-outline-secondary" id="clearFilesBtn">
                        <i class="bi bi-x-circle me-1"></i>Clear
                    </button>
                </div>
                <ul id="fileListItems" class="list-group list-group-flush"></ul>
                <div class="mt-3">
                    <button type="button" class="btn btn-primary" id="parseBtn">
                        <i class="bi bi-magic me-2"></i>Parse Files &amp; Generate Form
                    </button>
                </div>
            </div>
        </div>
    </div>

    <!-- Spinner -->
    <div id="parseSpinner" class="text-center py-4 d-none">
        <div class="tg-spinner mb-3">
            <div class="spinner-border text-primary" role="status" style="width:3rem;height:3rem;">
                <span class="visually-hidden">Parsing files…</span>
            </div>
        </div>
        <p class="text-muted">Parsing your Terraform files…</p>
    </div>

    <!-- Warnings -->
    <div id="warningsContainer" class="row justify-content-center d-none mb-3">
        <div class="col-lg-10">
            <div id="warningsList" class="alert alert-warning"></div>
        </div>
    </div>

    <!-- Main form area -->
    <div id="formArea" class="d-none">
        <div class="row justify-content-center">
            <div class="col-lg-7">
                <div class="d-flex align-items-center justify-content-between mb-4">
                    <h4 class="mb-0">
                        <i class="bi bi-list-check me-2 text-primary"></i>
                        Variables
                        <span id="varCount" class="badge bg-primary ms-2 align-middle"></span>
                    </h4>
                    <div class="d-flex gap-2">
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="expandAllBtn">
                            <i class="bi bi-arrows-expand me-1"></i>Expand All
                        </button>
                        <button type="button" class="btn btn-sm btn-outline-secondary" id="collapseAllBtn">
                            <i class="bi bi-arrows-collapse me-1"></i>Collapse All
                        </button>
                    </div>
                </div>
                <div id="variablesForm"></div>

                <div class="mt-4 d-flex flex-wrap gap-2">
                    <button type="button" class="btn btn-primary btn-lg" id="downloadBtn" disabled>
                        <i class="bi bi-download me-2"></i>Download terraform.tfvars
                    </button>
                    <button type="button" class="btn btn-outline-secondary btn-lg" id="copyBtn" disabled>
                        <i class="bi bi-clipboard me-2"></i>Copy to Clipboard
                    </button>
                </div>
            </div>

            <!-- Live preview -->
            <div class="col-lg-5">
                <div class="tg-preview-panel sticky-top" style="top: 1rem;">
                    <div class="d-flex align-items-center justify-content-between mb-2">
                        <h5 class="mb-0">
                            <i class="bi bi-eye me-2 text-muted"></i>Live Preview
                        </h5>
                        <div class="d-flex gap-2 align-items-center">
                            <span id="validationStatus" class="badge"></span>
                        </div>
                    </div>
                    <textarea id="previewTextarea" class="tg-preview-textarea form-control font-monospace"
                              readonly aria-label="Live preview of terraform.tfvars content"></textarea>
                </div>
            </div>
        </div>
    </div>

    <!-- How it works -->
    <div id="howItWorks" class="row justify-content-center mt-5 pt-4 border-top">
        <div class="col-lg-10">
            <h4 class="text-center mb-4 text-muted">How it works</h4>
            <div class="row g-4">
                <div class="col-md-4">
                    <div class="tg-step-card">
                        <div class="tg-step-number">1</div>
                        <h6>Upload</h6>
                        <p class="text-muted small">Drop your <code>variables.tf</code> (and optionally example files) into the zone above.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="tg-step-card">
                        <div class="tg-step-number">2</div>
                        <h6>Fill</h6>
                        <p class="text-muted small">Fill in the generated form. Required fields are highlighted. Descriptions guide you.</p>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="tg-step-card">
                        <div class="tg-step-number">3</div>
                        <h6>Download</h6>
                        <p class="text-muted small">Click "Download terraform.tfvars" to get a ready-to-use file, or copy it to clipboard.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
